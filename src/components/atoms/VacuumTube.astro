---
interface Props {
  color?: "orange" | "green";
  delay?: number;
}

const { color = "orange", delay = 0 } = Astro.props;

const glowColor = color === "green" ? "var(--color-crt-green)" : "var(--color-atomic-orange)";
const glowDim = color === "green" ? "var(--color-crt-green-dim)" : "var(--color-atomic-orange-dim)";
---

<div
  class="w-6 h-10 shrink-0 rounded-t rounded-b-lg relative overflow-hidden"
  style={`background: linear-gradient(180deg, #3a3530 0%, #2a2520 100%); border: 1px solid var(--color-border-metal); border-radius: 4px 4px 8px 8px;`}
>
  <div
    class="absolute rounded-full"
    style={`
      bottom: 8px;
      left: 50%;
      transform: translateX(-50%);
      width: 8px;
      height: 8px;
      background: ${glowColor};
      box-shadow: 0 0 10px ${glowColor}, 0 0 20px ${glowDim};
      animation: tube-flicker 3s ease-in-out infinite;
      animation-delay: ${delay}s;
    `}
  ></div>
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-3 h-1 rounded-b-sm"
    style={`background: var(--color-rivet); border-radius: 0 0 2px 2px;`}
  ></div>
</div>
