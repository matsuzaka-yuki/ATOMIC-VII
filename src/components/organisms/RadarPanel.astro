---
import Rivet from "../atoms/Rivet.astro";

interface Props {
  radiationLevel?: string;
  signalStrength?: string;
}

const { radiationLevel = "0.34", signalStrength = "87%" } = Astro.props;
---

<div
  class="rounded-lg p-5 relative"
  style="background: linear-gradient(145deg, #0a1a0a 0%, #0d200d 50%, #0a1a0a 100%); border: 3px solid var(--color-border-metal); box-shadow: inset 0 0 60px rgba(51,255,102,0.05), 4px 4px 0 rgba(0,0,0,0.5);"
>
  <Rivet position="tl" />
  <Rivet position="tr" />

  <div class="flex justify-between items-center mb-4 pb-2" style="border-bottom: 1px solid var(--color-crt-green-dim);">
    <span class="text-[11px] tracking-[3px] uppercase" style="color: var(--color-crt-green); text-shadow: 0 0 8px var(--color-crt-green-glow);">
      ◉ 辐射监测雷达
    </span>
    <span class="text-[10px]" style="color: var(--color-crt-green-dim);">
      N 39.9042° E 116.4074°
    </span>
  </div>

  <div
    class="w-full aspect-square rounded-full relative overflow-hidden mb-4"
    style="background: radial-gradient(circle, #0d200d 0%, #081008 100%); border: 2px solid var(--color-crt-green-dim); box-shadow: inset 0 0 40px rgba(51,255,102,0.1);"
  >
    <div class="absolute inset-0">
      {[33, 66, 100].map((size) => (
        <div
          class="absolute rounded-full border"
          style={`
            width: ${size}%;
            height: ${size}%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            border-color: rgba(51, 255, 102, 0.15);
          `}
        ></div>
      ))}

      <div class="absolute w-full h-px top-1/2" style="background: rgba(51, 255, 102, 0.1);"></div>
      <div class="absolute h-full w-px left-1/2" style="background: rgba(51, 255, 102, 0.1);"></div>
    </div>

    <div
      class="absolute top-1/2 left-1/2 w-1/2 h-0.5 origin-left"
      style="animation: radar-rotate 4s linear infinite; background: linear-gradient(90deg, var(--color-crt-green), transparent); box-shadow: 0 0 20px var(--color-crt-green-glow);"
    >
      <div
        class="absolute top-1/2 left-0 -translate-y-1/2 w-full"
        style="height: 100%; background: conic-gradient(from -90deg, transparent, rgba(51,255,102,0.15), transparent); transform-origin: left center; animation: radar-rotate 4s linear infinite;"
      ></div>
    </div>

    {[
      { top: "30%", left: "45%", delay: "0s" },
      { top: "60%", left: "70%", delay: "0.5s" },
      { top: "40%", left: "25%", delay: "1s" },
      { top: "75%", left: "40%", delay: "1.5s" },
    ].map((blip) => (
      <div
        class="absolute w-1.5 h-1.5 rounded-full"
        style={`
          top: ${blip.top};
          left: ${blip.left};
          background: var(--color-crt-green);
          box-shadow: 0 0 8px var(--color-crt-green), 0 0 16px var(--color-crt-green-glow);
          animation: blip-pulse 2s ease-in-out infinite;
          animation-delay: ${blip.delay};
        `}
      ></div>
    ))}

    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 rounded-full"
      style="background: var(--color-crt-green); box-shadow: 0 0 10px var(--color-crt-green);"
    ></div>
  </div>

  <div class="grid grid-cols-2 gap-2">
    {[
      { label: "辐射等级", value: radiationLevel },
      { label: "探测目标", value: "4" },
      { label: "扫描范围", value: "50 km" },
      { label: "信号强度", value: signalStrength },
    ].map((item) => (
      <div
        class="px-3 py-2 text-[10px]"
        style="background: rgba(51, 255, 102, 0.05); border: 1px solid rgba(51, 255, 102, 0.15);"
      >
        <div class="tracking-[2px] uppercase" style="color: var(--color-crt-green-dim);">
          {item.label}
        </div>
        <div
          class="text-sm mt-0.5"
          style="color: var(--color-crt-green); text-shadow: 0 0 8px var(--color-crt-green-glow);"
        >
          {item.value}
        </div>
      </div>
    ))}
  </div>
</div>

<script>
  function fluctuate(base: number, range: number): string {
    return (base + (Math.random() - 0.5) * range).toFixed(2);
  }

  setInterval(() => {
    const radEl = document.getElementById("radiation-level");
    const sigEl = document.getElementById("signal-strength");
    if (radEl) radEl.textContent = fluctuate(0.34, 0.1);
    if (sigEl) sigEl.textContent = Math.floor(85 + Math.random() * 10) + "%";
  }, 2000);
</script>
