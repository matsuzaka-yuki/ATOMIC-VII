---
interface Props {
  value: number;
  unit: string;
  displayValue?: string;
  size?: "sm" | "md";
}

const { value, unit, displayValue, size = "md" } = Astro.props;

const sizeClasses = size === "sm"
  ? "w-24 h-24"
  : "w-[120px] h-[120px]";

const textSize = size === "sm" ? "text-xl" : "text-2xl";
const shownValue = displayValue ?? String(value);
---

<div class={`${sizeClasses} mx-auto mb-4 relative`}>
  <div
    class="w-full h-full rounded-full relative"
    style={`
      border: 4px solid var(--color-border-metal);
      background: conic-gradient(
        from 220deg,
        var(--color-crt-green) 0deg,
        var(--color-crt-green) calc(${value} * 1deg),
        transparent calc(${value} * 1deg),
        transparent 280deg
      );
      box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
    `}
  >
    <div
      class="absolute inset-2 rounded-full"
      style="background: var(--color-bg-panel);"
    ></div>
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60px] h-[60px] rounded-full z-[1]"
      style="background: var(--color-bg-dark); border: 2px solid var(--color-border-metal);"
    ></div>
  </div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-[2] text-center">
    <div
      class={`font-heading ${textSize} font-bold leading-none`}
      style="color: var(--color-crt-green); text-shadow: 0 0 10px var(--color-crt-green-glow);"
    >
      {shownValue}
    </div>
    <div class="text-[10px] tracking-[2px]" style="color: var(--color-crt-green-dim);">
      {unit}
    </div>
  </div>
</div>
