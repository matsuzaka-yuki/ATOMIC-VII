---
import Rivet from "../atoms/Rivet.astro";

type RivetPosition = "tl" | "tr" | "bl" | "br";

interface Props {
  class?: string;
  tag?: string;
  rivets?: RivetPosition[];
}

const { class: className = "", tag = "div", rivets = ["tl", "tr", "bl", "br"] } = Astro.props;
const Tag = tag as any;
---

<Tag class={`metal-panel-bg ${className}`}>
  {rivets.map((pos) => (
    <Rivet position={pos} />
  ))}
  <slot />
</Tag>
