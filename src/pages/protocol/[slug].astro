---
import Layout from "../../components/layouts/Layout.astro";
import Breadcrumb from "../../components/molecules/Breadcrumb.astro";
import SectionHeader from "../../components/molecules/SectionHeader.astro";
import ArtDecoDivider from "../../components/atoms/ArtDecoDivider.astro";
import MetalPanel from "../../components/molecules/MetalPanel.astro";
import { securityProtocols } from "../../data/protocols";

export function getStaticPaths() {
  return Object.values(securityProtocols).map((proto) => ({
    params: { slug: proto.slug },
    props: { proto },
  }));
}

const { proto } = Astro.props;
const breadcrumbItems = [
  { label: "ATOMIC-7", href: "/" },
  { label: "安全协议", href: "/security" },
];

const clsColorMap: Record<string, { bg: string; color: string }> = {
  "top-secret": { bg: "var(--color-warning-red)", color: "#fff" },
  secret: { bg: "var(--color-atomic-orange)", color: "#fff" },
  confidential: { bg: "var(--color-olive-drab-light)", color: "#fff" },
  unclassified: { bg: "var(--color-border-metal)", color: "var(--color-text-primary)" },
};
const cls = clsColorMap[proto.classificationLevel] ?? clsColorMap.unclassified;
---

<Layout title={`ATOMIC-7 // ${proto.name}`} currentPath={`/protocol/${proto.slug}`}>
  <Breadcrumb items={breadcrumbItems} current={proto.name} />

  <section class="py-16 px-6 relative">
    <div class="max-w-[1400px] mx-auto">
      <div class="flex flex-col lg:flex-row gap-8 mb-16 fade-in">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-4xl">{proto.icon}</span>
            <div>
              <div class="font-heading text-[11px] tracking-[3px] uppercase" style="color: var(--color-atomic-orange);">
                {proto.code} // SECURITY PROTOCOL
              </div>
              <h1 class="font-heading text-4xl md:text-5xl font-bold uppercase tracking-[4px]" style="color: var(--color-text-primary);">
                {proto.name}
              </h1>
            </div>
          </div>
          <p class="font-typewriter text-sm mb-6" style="color: var(--color-atomic-orange); letter-spacing: 2px;">
            "{proto.tagline}"
          </p>
          <p class="text-[13px] leading-[1.8] mb-6" style="color: var(--color-text-secondary);">
            {proto.description}
          </p>
          <div class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-2 px-3 py-1.5 text-[10px] font-bold tracking-[2px] uppercase" style={`background: ${cls.bg}; color: ${cls.color};`}>
              {proto.classification}
            </span>
            <span class="inline-flex items-center gap-2 px-3 py-1.5 text-[10px] tracking-[2px] uppercase" style="background: rgba(232,101,26,0.1); border: 1px solid var(--color-atomic-orange-dim); color: var(--color-atomic-orange);">
              生效 {proto.effectiveDate}
            </span>
            <span class="inline-flex items-center gap-2 px-3 py-1.5 text-[10px] tracking-[2px] uppercase" style="background: rgba(51,255,102,0.05); border: 1px solid rgba(51,255,102,0.15); color: var(--color-crt-green);">
              修订 {proto.lastRevised}
            </span>
          </div>
        </div>
        <div class="lg:w-[400px] flex-shrink-0">
          <MetalPanel class="p-6">
            <h3 class="font-heading text-sm font-semibold uppercase tracking-[2px] mb-5 pb-2" style="color: var(--color-text-primary); border-bottom: 1px solid var(--color-border-metal);">
              协议概要
            </h3>
            <div class="space-y-4 mb-5">
              <div>
                <div class="text-[10px] tracking-[2px] uppercase mb-1" style="color: var(--color-text-secondary);">负责部门</div>
                <div class="text-[12px]" style="color: var(--color-text-primary);">{proto.responsible}</div>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              {proto.keyNumbers.map((stat) => (
                <div class="text-center p-3" style="background: rgba(26,24,20,0.6); border: 1px solid var(--color-border-metal);">
                  <div class="font-heading text-lg font-bold text-glow-green" style="color: var(--color-crt-green);">
                    {stat.value}
                  </div>
                  <div class="text-[10px] tracking-[1px] uppercase mt-1" style="color: var(--color-text-secondary);">
                    {stat.label}
                  </div>
                </div>
              ))}
            </div>
          </MetalPanel>
        </div>
      </div>

      <ArtDecoDivider />

      <section class="py-10 px-0 fade-in" style="background: linear-gradient(180deg, var(--color-bg-dark) 0%, #1e1b16 100%);">
        <div class="max-w-[1000px] mx-auto">
          <div class="mb-10">
            <div class="font-typewriter text-[12px] mb-4 tracking-[2px]" style="color: var(--color-crt-green-dim);">
              PROTOCOL OVERVIEW
            </div>
            <p class="text-[13px] leading-[1.8]" style="color: var(--color-text-secondary); border-left: 3px solid var(--color-atomic-orange); padding-left: 16px;">
              {proto.overview}
            </p>
          </div>
        </div>
      </section>

      <ArtDecoDivider />

      <SectionHeader tag="Protocol Sections" label="协议条款" />

      <div class="max-w-[1000px] mx-auto mb-8">
        {proto.sections.map((section, i) => (
          <div class="metal-panel-bg p-6 mb-6 fade-in">
            <div class="flex items-start gap-4 mb-4">
              <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center" style="background: rgba(232,101,26,0.15); border: 1px solid var(--color-atomic-orange-dim);">
                <span class="text-xl">{section.icon}</span>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-1">
                  <span class="font-heading text-[10px] font-bold tracking-[2px]" style="color: var(--color-atomic-orange);">
                    SECTION {String(i + 1).padStart(2, "0")}
                  </span>
                </div>
                <h3 class="font-heading text-lg font-semibold uppercase tracking-[1px]" style="color: var(--color-text-primary);">
                  {section.title}
                </h3>
              </div>
            </div>
            <p class="text-[12px] leading-[1.8]" style="color: var(--color-text-secondary); padding-left: 56px;">
              {section.content}
            </p>
          </div>
        ))}
      </div>

      <ArtDecoDivider />

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div>
          <SectionHeader tag="Violations & Penalties" label="违规与处罚" />
          <div class="metal-panel-bg p-6">
            <div class="flex flex-col gap-4">
              {proto.penalties.map((penalty, i) => (
                <div class="flex items-start gap-3">
                  <span class="font-heading text-sm font-bold flex-shrink-0 mt-0.5" style="color: var(--color-warning-red);">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <p class="text-[12px] leading-[1.7]" style="color: var(--color-text-secondary);">
                    {penalty}
                  </p>
                </div>
              ))}
            </div>
            <div class="mt-6 p-4" style="background: rgba(196,30,30,0.1); border: 1px solid var(--color-warning-red-dim);">
              <div class="text-[10px] font-bold tracking-[2px] uppercase mb-2" style="color: var(--color-warning-red);">
                \u26D4 重要提示
              </div>
              <p class="text-[11px] leading-[1.7]" style="color: var(--color-text-secondary);">
                所有安全违规行为将被永久记录在个人安全档案中，作为权限审批、岗位晋升及年度考核的重要参考依据。故意违反安全协议者将被列入观察名单，为期不少于12个月。
              </p>
            </div>
          </div>
        </div>

        <div>
          <SectionHeader tag="Related Protocols" label="关联协议" />
          <div class="flex flex-col gap-4 mb-8">
            {proto.relatedProtocols.map((rp) => (
              <div class="metal-panel-bg p-5 flex items-center justify-between gap-4 fade-in">
                <div>
                  <div class="font-typewriter text-[11px] mb-1" style="color: var(--color-crt-green-dim);">
                    {rp.code}
                  </div>
                  <div class="font-heading text-sm font-semibold uppercase tracking-[1px]" style="color: var(--color-text-primary);">
                    {rp.name}
                  </div>
                </div>
                <span class="font-heading text-[10px] tracking-[2px] uppercase" style="color: var(--color-atomic-orange);">
                  →
                </span>
              </div>
            ))}
          </div>

          <SectionHeader tag="Document Control" label="文档控制" />
          <div class="metal-panel-bg p-6">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <div class="text-[10px] tracking-[2px] uppercase mb-1" style="color: var(--color-text-secondary);">协议编号</div>
                <div class="font-heading text-sm font-bold" style="color: var(--color-text-primary);">{proto.code}</div>
              </div>
              <div>
                <div class="text-[10px] tracking-[2px] uppercase mb-1" style="color: var(--color-text-secondary);">密级</div>
                <div class="font-heading text-sm font-bold" style={`color: ${cls.color};`}>{proto.classification}</div>
              </div>
              <div>
                <div class="text-[10px] tracking-[2px] uppercase mb-1" style="color: var(--color-text-secondary);">生效日期</div>
                <div class="text-[12px]" style="color: var(--color-text-primary);">{proto.effectiveDate}</div>
              </div>
              <div>
                <div class="text-[10px] tracking-[2px] uppercase mb-1" style="color: var(--color-text-secondary);">最近修订</div>
                <div class="text-[12px]" style="color: var(--color-text-primary);">{proto.lastRevised}</div>
              </div>
              <div class="col-span-2">
                <div class="text-[10px] tracking-[2px] uppercase mb-1" style="color: var(--color-text-secondary);">负责部门</div>
                <div class="text-[12px]" style="color: var(--color-text-primary);">{proto.responsible}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
