---
import Layout from "../components/layouts/Layout.astro";
import { channels, transmissions, gauges } from "../data/comms";

const statusMap: Record<string, string> = { online: "在线", weak: "信号弱", offline: "离线" };
const statusDotMap: Record<string, string> = { online: "green", weak: "orange", offline: "red" };
---

<Layout title="ATOMIC-7 // 通讯频道" currentPath="/comms">
  <div class="cmp-page">

    <div class="cmp-breadcrumb fade-in">
      <a href="/">ATOMIC-7</a>
      <span class="sep">›</span>
      <span class="current">通讯频道</span>
    </div>

    <!-- Channel Rack -->
    <section class="cmp-section fade-in">
      <div class="cmp-section-header">
        <h1 class="cmp-section-title">通讯频道</h1>
        <div class="cmp-section-tag">COMMS CENTER // CLASSIFIED</div>
      </div>

      <div class="cmp-channel-grid">
        {channels.map((ch) => (
          <div class={`cmp-channel-card${ch.status === "offline" ? " offline" : ""}`}>
            <div class="cmp-channel-topbar">
              <span class="cmp-channel-id">{ch.id}</span>
              <div class={`cmp-channel-status ${ch.status}`}>
                <span class={`status-dot ${statusDotMap[ch.status]}`}></span>
                <span>{statusMap[ch.status]}</span>
              </div>
            </div>
            <div class="cmp-channel-body">
              <div class="cmp-channel-name">{ch.name}</div>
              <div class="cmp-channel-freq" style={ch.frequencyOverride ? `color: ${ch.frequencyOverride.color}` : ""}>
                <span class="freq-prefix">▶</span> {ch.frequencyOverride ? ch.frequencyOverride.prefix : ""} {ch.frequency}
              </div>
              <div class="cmp-waveform">
                {Array.from({ length: 12 }).map(() => <div class="cmp-waveform-bar"></div>)}
              </div>
              <div class="cmp-channel-footer">
                <div class="cmp-signal-strength">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <div class={`cmp-signal-bar${i < ch.signalBars ? " active" : ""}`}></div>
                  ))}
                </div>
                <div class="cmp-channel-activity" style={ch.activityOverride ? `color: ${ch.activityOverride.color}` : ""}>
                  {ch.activityOverride ? ch.activityOverride.text : ch.lastActivity}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="cmp-divider fade-in">
      <div class="line"></div>
      <div class="line"></div>
    </div>

    <!-- CRT Transmission Terminal -->
    <section class="cmp-section fade-in">
      <div class="cmp-section-header">
        <h2 class="cmp-section-title">实时通讯记录</h2>
        <div class="cmp-section-tag">LIVE TRANSMISSION LOG // MONITORED</div>
      </div>

      <div class="cmp-terminal-frame">
        <div class="cmp-terminal-header">
          <span class="cmp-terminal-title">◉ SECURE TERMINAL</span>
          <div class="cmp-terminal-indicators">
            <div class="cmp-terminal-ind rec"></div>
            <div class="cmp-terminal-ind trx"></div>
            <div class="cmp-terminal-ind err"></div>
          </div>
        </div>
        <div class="cmp-transmission-log">
          {transmissions.map((t) => (
            <div class={`cmp-tx-entry ${t.direction}`}>
              <div class="cmp-tx-avatar">{t.avatar}</div>
              <div class="cmp-tx-content">
                <div class="cmp-tx-meta">
                  {t.direction === "received" && <span class="cmp-tx-sender">{t.sender}</span>}
                  <span class="cmp-tx-time">{t.time}</span>
                  {t.direction === "sent" && <span class="cmp-tx-sender">{t.sender}</span>}
                  <span class={`cmp-tx-badge ${t.badge}`}>{t.badge.toUpperCase()}</span>
                </div>
                <div class="cmp-tx-message">{t.message}</div>
              </div>
            </div>
          ))}
          <div class="cmp-typing">
            <div class="cmp-typing-dots"><span></span><span></span><span></span></div>
            <span>SCIENCE-LAB-03 正在输入...</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Analog Gauge Dashboard -->
    <section class="cmp-section fade-in">
      <div class="cmp-section-header">
        <h2 class="cmp-section-title">信号分析仪表</h2>
        <div class="cmp-section-tag">SIGNAL ANALYSIS // REAL-TIME</div>
      </div>

      <div class="cmp-gauge-grid">
        {gauges.map((g) => (
          <div class="cmp-gauge-item">
            <div class="cmp-gauge-ring">
              <svg viewBox="0 0 100 100">
                <circle class="cmp-gauge-bg" cx="50" cy="50" r="40"></circle>
                <circle class="cmp-gauge-ticks" cx="50" cy="50" r="40" stroke-dasharray="2 5.7" stroke-dashoffset="0"></circle>
                <circle class={`cmp-gauge-fill ${g.speed}`} cx="50" cy="50" r="40" style={`--fill-offset: ${Math.round(g.fillOffset * (251/283))}`}></circle>
              </svg>
              <div class="cmp-gauge-value">{g.value}</div>
            </div>
            <div class="cmp-gauge-label">{g.label}</div>
            <div class="cmp-gauge-sublabel">{g.sublabel}</div>
          </div>
        ))}
      </div>
    </section>

    <div class="cmp-divider fade-in">
      <div class="line"></div>
      <div class="line"></div>
    </div>
  </div>
</Layout>
